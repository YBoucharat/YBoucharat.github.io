
@article{boucharat_probabilistic_2025,
	title = {Probabilistic inversion of sea level, tectonics, and coral reef morphogenesis},
	url = {https://archimer.ifremer.fr/doc/00984/109624/},
	doi = {10.22541/essoar.176166824.49625300/v1},
	abstract = {coastal landforms constitute a worldwide archive that intricately records past sea level, tectonics, and geomorphic processes, yet unraveling the complex interplay of these processes driving the morphogenesis of the shorelines remains a challenge. albeit forward landscape evolution modeling has proven successful in deciphering either sea-level, tectonics, or geomorphic processes independently, this strategy rests upon hypotheses regarding the other two aspects. we circumvent this limitation by inverting coral reef terrace morphologies using the new model rosetta (resolving sea level, ecosystems and tectonics from terrace analysis), which produces probabilistic reconstructions of past sea level, tectonic vertical motion, erosion processes, and reef growth rates from coastal landforms. we first benchmark rosetta on synthetic terraces sequences and then on the canonical landforms of sumba island, indonesia. beyond reconstructions, our probabilistic approach allows to highlight periods of time and sea level that can confidently be resolved from the geomorphological archive, and conversely identifies periods where the archive is insufficient to be conclusive. a successful remedy is to jointly invert multiple profiles using rosetta, improving the confidence of the results. we provide here a probabilistic reconstruction of continuous relative sea-level history and rates of change over the late quaternary. periods of time with sea-level rise rates analogous to present day and projected rises are identified, and coral reef responses to such conditions are quantified over millennial timescales, indicating that sumba-type coral reefs could hardly keep-up with ipcc-predicted rates of sea-level rise for the next century.},
	language = {en},
	urldate = {2026-05-04},
	journal = {ESS Open Archive},
	publisher = {Wiley},
	author = {Boucharat, Yannick and Husson, Laurent and de Gelder, Gino and Pastier, Anne-Morwenn and Chauveau, Denovan and Bodin, Thomas and Authemayou, Christine and Martinod, Joseph and Pedoja, Kevin and Solihuddin, Tubagus and Cahyarini, Sri Yudawati and de Gelder, Gino and Pastier, Anne-Morwenn and Chauveau, Denovan and Bodin, Thomas and Authemayou, Christine and Martinod, Joseph and Pedoja, Kevin and Solihuddin, Tubagus and Cahyarini, Sri Yudawati},
	month = oct,
	year = {2025},
	file = {Full Text PDF:C\:\\Users\\Yanni\\Zotero\\storage\\WGYB3MRL\\Boucharat et al. - 2025 - Probabilistic inversion of sea level, tectonics, and coral reef morphogenesis.pdf:application/pdf},
  selected = true,
}

@article{de_gelder_bayesian_2025,
	title = {Bayesian reconstruction of sea level and hydroclimates from coastal landform inversion: application to {Santa} {Cruz} ({US}) and {Gulf} of {Corinth}},
	volume = {13},
	issn = {2196-6311},
	shorttitle = {Bayesian reconstruction of sea level and hydroclimates from coastal landform inversion},
	url = {https://esurf.copernicus.org/articles/13/941/2025/},
	doi = {10.5194/esurf-13-941-2025},
	abstract = {Quantifying Quaternary sea-level changes and hydroclimatic conditions is an important challenge, given their intricate relation with paleo-climate, ice-sheets, and geodynamics. The world's coastlines provide an enormous geomorphologic archive, from which forward landscape evolution modeling studies have shown their potential to unravel paleo sea levels, albeit at the cost of assumptions on the genesis of these landforms. We take a next step, by applying a Bayesian approach to jointly invert the geometries of multiple coastal terrace sequences to paleo sea- and lake-level variations and extract past hydroclimatic conditions. Using a Markov chain Monte Carlo sampling method, we first test our approach on synthetic marine terrace profiles as proof of concept and then benchmark our model on an observed marine terrace sequence in Santa Cruz (US). We successfully reproduce observed sequence morphologies and simultaneously obtain probabilistic estimates for past sea-level variations, as well as for other model parameters, such as uplift and erosion rates. When applied to the semi-isolated Gulf of Corinth (Greece), our method allows the geomorphic Rosetta stone to be deciphered at an unprecedented resolution, revealing the connectivity between the Lake/Gulf of Corinth and the open sea for different hydroclimatic conditions. Eustatic sea levels and changing sill depths drive marine and transitional phases during interglacial and interstadial periods, whereas wetter and drier hydroclimates, respectively, over- and underfill Lake Corinth during interstadial and glacial periods.},
	language = {English},
	number = {5},
	urldate = {2026-05-04},
	journal = {Earth Surface Dynamics},
	publisher = {Copernicus GmbH},
	author = {de Gelder, Gino and Hedjazian, Navid and Husson, Laurent and Bodin, Thomas and Pastier, Anne-Morwenn and Boucharat, Yannick and Pedoja, Kevin and Solihuddin, Tubagus and Cahyarini, Sri Yudawati},
	month = sep,
	year = {2025},
	pages = {941--958},
	file = {Full Text PDF:C\:\\Users\\Yanni\\Zotero\\storage\\E2T6ZSRG\\de Gelder et al. - 2025 - Bayesian reconstruction of sea level and hydroclimates from coastal landform inversion application.pdf:application/pdf},
}


@article{husson_reef_2018,
	title = {Reef {Carbonate} {Productivity} {During} {Quaternary} {Sea} {Level} {Oscillations}},
	volume = {19},
	copyright = {© 2018. American Geophysical Union. All Rights Reserved.},
	issn = {1525-2027},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/2017GC007335},
	doi = {10.1002/2017GC007335},
	abstract = {Global variations in reef productivity during the Quaternary depend on external parameters that may alter the global chemical balance in the oceans and atmosphere. We designed a numerical model that simulates reef growth, erosion, and sedimentation on coastlines undergoing sea level oscillations, and uplift or subsidence. We further develop a probabilistic evaluation that accounts for variable vertical ground motion, erosion, and foundation morphologies. Absolute sea level change appears primordial, as productivity must have increased by an order of magnitude since the onset of the glacial cycles, ∼2.6 Ma. But most important is relative sea level change, i.e., eustasy modulated by uplift or subsidence, that rejuvenates the accommodation space and exposes pristine domains of the shore to active reefs at each cycle. Integrated over the long-term, vertical land motion sets the pace of reef growth: productivity in tectonically unstable domains is thus expected to be up to 10 times higher than in stable regions, if any. We quantify the global length of reef coasts and the probability density functions for slopes and uplift rates. Productivity waxes during transgressions to reach 2–8 and wanes during highstands, which may contribute to increase atmospheric pCO2 by several tens of ppm during deglaciations. Over the last 1.5 Ma, reefs precipitated ∼0.8 × 106 (∼500 × 103 km3), the equivalent of a 1 m-thick layer spread over the entire surface of the Earth. This production modulates the calcium budget, for it represents some 30\% of the modern Ca flux in the ocean.},
	language = {en},
	number = {4},
	urldate = {2025-05-16},
	journal = {Geochemistry, Geophysics, Geosystems},
	author = {Husson, L. and Pastier, A.-M. and Pedoja, K. and Elliot, M. and Paillard, D. and Authemayou, C. and Sarr, A.-C. and Schmitt, A. and Cahyarini, S. Y.},
	year = {2018},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1002/2017GC007335},
	keywords = {carbonate, coral reefs, modeling, paleoclimate, sea level},
	pages = {1148--1164},
	file = {Full Text PDF:C\:\\Users\\Yanni\\Zotero\\storage\\TQ9MLWYY\\Husson et al. - 2018 - Reef Carbonate Productivity During Quaternary Sea Level Oscillations.pdf:application/pdf;Snapshot:C\:\\Users\\Yanni\\Zotero\\storage\\ZJDXE8XI\\2017GC007335.html:text/html},
}

@article{pastier_genesis_2019,
	title = {Genesis and {Architecture} of {Sequences} of {Quaternary} {Coral} {Reef} {Terraces}: {Insights} {From} {Numerical} {Models}},
	volume = {20},
	copyright = {©2019. American Geophysical Union. All Rights Reserved.},
	issn = {1525-2027},
	shorttitle = {Genesis and {Architecture} of {Sequences} of {Quaternary} {Coral} {Reef} {Terraces}},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1029/2019GC008239},
	doi = {10.1029/2019GC008239},
	abstract = {The variety of coral reefs morphologies highlights their sensitivities to several forcings; fossil reefs stack in sequences that are accordingly diverse. In order to understand their genesis and architectures, we devised a numerical approach, accounting for Quaternary sea level oscillations, vertical land motion, initial slope, wave erosion, and reef growth. We first test our model on the subsiding sequence of Hawaii and on the uplifting sequence of Wangi-Wangi (Sulawesi) that bears active barriers. We then construct a parametric study that we analyze based on a comprehensive yet compact description of sequences as barcodes, that depict the vertical distribution of a few geometrical characteristics (number, width, and height of the terraces and barriers). We find that geological factors suffice to explain the variety of architectures of reefal sequences at first order, regardless of additional ecosystemic processes. Vertical land motion and foundation slopes are the prime players, while reef growth rates only play a minor role. Barriers may develop both in uplift and subsidence mode, and their preservation attests for the erosional power. Last, we reappraise the genesis of sequences and find that sequences do not fingerprint discrete events of sea level oscillations but a continuous process harrowed by stochastic events: Major sea level fluctuations can be overrepresented by several terraces or conversely absent; reoccupations may yield composite terraces representing multiple events. Overall, sequences shall not be regarded as stacks of reef bodies forming during sea level highstands, which implies that the commonly assumed bijective relationship between sea level highstands and terraces shall be abandoned.},
	language = {en},
	number = {8},
	urldate = {2025-05-16},
	journal = {Geochemistry, Geophysics, Geosystems},
	author = {Pastier, A.-M. and Husson, L. and Pedoja, K. and Bézos, A. and Authemayou, C. and Arias-Ruiz, C. and Cahyarini, S. Y.},
	year = {2019},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1029/2019GC008239},
	keywords = {coral reefs, geomorphology, numerical modeling, reef terraces},
	pages = {4248--4272},
	file = {Full Text PDF:C\:\\Users\\Yanni\\Zotero\\storage\\63NBGGJC\\Pastier et al. - 2019 - Genesis and Architecture of Sequences of Quaternary Coral Reef Terraces Insights From Numerical Mod.pdf:application/pdf;Snapshot:C\:\\Users\\Yanni\\Zotero\\storage\\YPMFNFQQ\\2019GC008239.html:text/html},
}


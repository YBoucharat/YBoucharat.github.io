{% if site.presentations %}
  <div class="presentations">
    {% assign presentation = site.presentations | sort: 'year' | reverse %}
    
    <div class="presentation-schedule">
        <h2>{{ course.title }}</h2>

        <table class="table table-sm table-responsive">
            <thead>
            <tr>
                <th>Year</th>
                <th>Date</th>
                <th>Topic</th>
                <th>Materials</th>
            </tr>
            </thead>
            <tbody>
              </tr>
                <td>
                  {% if presentation.year %}
                    <strong>{{ presentation.year }}<strong>
                  {% endif %}
                <td>
                  {% if presentation.date %}
                    <strong>{{ presentation.date }}<strong>
                  {% endif %}
                <td>
                  {% if presentation.title %}
                    <strong>{{ presentation.title }}<strong>
                  {% endif %}
                  {% if presentation.description %}
                    <div class="presentation-description">{{ presentation.description | markdownify }}</div>
                  {% endif %}
                </td>
                <td>
                  {% if presentation.materials %}
                    <ul class="schedule-materials">
                      {% for material in presentation.materials %}
                        <li>
                          {% if material.url %}
                            {% if material.url contains '://' %}
                              <a href="{{ material.url }}" target="_blank">{{ material.name }}</a>
                            {% else %}
                              <a href="{{ material.url | relative_url }}" target="_blank">{{ material.name }}</a>
                            {% endif %}
                          {% else %}
                            {{ material.name }}
                          {% endif %}
                        </li>
                      {% endfor %}
                    </ul>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
                  
                    
                

        {% if presentation.description %}
        <div class="presentation-description">
            {{ presentation.description | markdownify }}
        </div>
        {% endif %}

        {% if presentation.year %}
          <p><strong>Year:</strong> {{ presentation.year }}</p>
        {% endif %}

        {% if presentation.date %}
          <p><strong>Date:</strong> {{ presentation.date }}</p>
        {% endif %}

        {% if presentation.location %}
          <p><strong>Location:</strong> {{ presentation.location }}</p>
        {% endif %}




    {% for year_group in presentations_by_year %}
      <h2 class="year">{{ year_group.name }}</h2>
      <div class="pres-list">
        {% assign year_presentations = year_group.items | sort: 'term' %}
        {% for pres in year_presentations %}

          <div class="pres-item">
            <h3 class="pres-title">
              <a href="{{ pres.url | relative_url }}">{{ pres.title }}</a>
            </h3>

            <div class="pres-meta">
              {% if pres.term %}
                <span class="pres-term">{{ pres.term }}</span>
              {% endif %}

              {% if pres.instructor %}
                <span class="pres-instructor">{{ pres.instructor }}</span>
              {% endif %}
            </div>

            {% if pres.description %}
              <div class="pres-description">
                {{ pres.description | markdownify }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endfor %}
  </div>
{% else %}
  <p>No presentations available yet.</p>
{% endif %}

{% if site.presentations %}
  <div class="presentations">
    <table class="table table-sm table-responsive">
      <thead>
        <tr>
          <th>Year</th>
          <th>Date</th>
          <th>Topic</th>
          <th>Location</th>
          <th>Materials</th>
        </tr>
      </thead>
      <tbody>
        {% assign sorted_presentations = site.presentations | sort: 'year' | reverse %}
        {% for presentation in sorted_presentations %}
          <tr>
            <td>
              {% if presentation.year %}
                <strong>{{ presentation.year }}</strong>
              {% endif %}
            </td>
            <td>
              {% if presentation.date %}
                {{ presentation.date | date: "%b %d" }}
              {% endif %}
            </td>
            <td>
              {% if presentation.title %}
                <strong>{{ presentation.title }}</strong>
              {% endif %}
              {% if presentation.description %}
                <div class="presentation-description">{{ presentation.description | markdownify }}</div>
              {% endif %}
            </td>
            <td>
              {% if presentation.location %}
                {{ presentation.location }}
              {% endif %}
            </td>
            <td>
              {% if presentation.materials %}
                <ul class="schedule-materials">
                  {% for material in presentation.materials %}
                    <li>
                      {% if material.url %}
                        {% if material.url contains '://' %}
                          <a href="{{ material.url }}" target="_blank">{{ material.name }}</a>
                        {% else %}
                          <a href="{{ material.url | relative_url }}" target="_blank">{{ material.name }}</a>
                        {% endif %}
                      {% else %}
                        {{ material.name }}
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
{% else %}
  <p>No presentations available yet.</p>
{% endif %}